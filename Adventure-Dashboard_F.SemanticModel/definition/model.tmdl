model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Transform File from Sales Data'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform File from Sales Data\Helper Queries'

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Territory Lookup","Product Categories Lookup","Product Subcategories Lookup","Product Lookup","Customer Lookup","Calendar Lookup","Calendar","Sales Data","Sample File","Parameter1","Transform Sample File","Transform File","Returns Data","Measures Table"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","MCP-PBIModeling","DevMode"]

ref table 'Territory Lookup'
ref table 'Product Categories Lookup'
ref table 'Product Subcategories Lookup'
ref table 'Product Lookup'
ref table 'Customer Lookup'
ref table 'Calendar Lookup'
ref table Calendar
ref table 'Sales Data'
ref table 'Returns Data'
ref table 'Measures Table'
ref table 'Price Adjustment (%)'
ref table 'Product Metric Selection'
ref table 'Customer Metric Selection'

ref cultureInfo en-US

